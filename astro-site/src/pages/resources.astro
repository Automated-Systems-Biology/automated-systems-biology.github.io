---
import Base from '../layouts/Base.astro';
import { resourceDocs } from '../lib/site.js';
const { docs, nav } = resourceDocs();
---
<Base title="Resources — Automated Systems Biology" page="resources">
  <main class="wrap">
    <div class="res-hero">
      <p class="eyebrow">Resources</p>
      <h1>Laboratory protocols &amp; reagents</h1>
      <p class="lead">Buffers, fixatives, culture media, staining and microscopy protocols, aseptic technique and
      safety — organised hierarchically. Click any item in the index to jump to it.</p>
    </div>
    <div class="res-layout">
      <aside class="res-nav">
        <div class="title">Protocols &amp; Reagents</div>
        <ul>
          {nav.map((n) => (
            <li class={`lvl-${n.depth}`}><a href={`#${n.id}`}>{n.title}</a></li>
          ))}
        </ul>
      </aside>
      <div class="res-content">
        {docs.map((d) => (
          <section class={`doc depth-${d.depth}`} id={d.id}>
            {d.crumb && <div class="crumb">{d.crumb}</div>}
            <h2>{d.title}</h2>
            {d.stub
              ? <p class="stub">This protocol page has not been filled in yet.</p>
              : <Fragment set:html={d.html} />}
          </section>
        ))}
      </div>
    </div>
  </main>
  <button class="icon-btn backtop" id="backtop" title="Back to top">↑</button>
  <footer class="footer"><div class="wrap">
    <span>© 2026 Automated Systems Biology Laboratory · PPKE-ITK</span>
    <span><a href="/">← Back to site</a></span>
  </div></footer>
</Base>
